# Enforce LF line endings for all text files to prevent cross-platform diffs.
* text=auto eol=lf

# Ensure these are always treated as text with LF
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.snap text eol=lf
*.sh text eol=lf

# Binary files — do not touch
*.jar binary
*.class binary
